# scatter-drop web — local dev fork config (copy to .env.local)
#
# scripts/dev-fork.sh prints a ready-to-paste block of these NEXT_PUBLIC_*
# values at the end of its run: the addresses come from
# contracts/deployments/<chainId>.json, while the chain id and RPC URL come
# from the script's own fork settings.

# Fork chain id + RPC (dev-fork re-labels the Sepolia fork to 31337 @ :8545 so
# it's distinct from real Sepolia — M1).
NEXT_PUBLIC_CHAIN_ID=31337
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# Deployment addresses. Either paste these (from dev-fork.sh), OR — simpler —
# copy the generated json so the app reads it at runtime without a rebuild:
#   cp contracts/deployments/31337.json apps/web/public/deployment.json
# NEXT_PUBLIC_DROP_FACTORY=0x...
# NEXT_PUBLIC_FEE_TOKEN=0x...
# NEXT_PUBLIC_AIRDROP_TOKEN=0x...
# NEXT_PUBLIC_TREASURY=0x...
