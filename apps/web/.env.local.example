# scatter-drop web — local dev fork config (copy to .env.local)
#
# The dev fork (scripts/dev-fork.sh) runs `anvil --fork-url $SEPOLIA_RPC_URL`,
# keeping Sepolia's chain id (11155111) on a local RPC.

# Fork RPC + chain id (defaults shown; override for a plain anvil 31337 run)
NEXT_PUBLIC_FORK_RPC=http://127.0.0.1:8545
NEXT_PUBLIC_FORK_CHAIN_ID=11155111

# Deployment addresses. Either set these here, OR (recommended for the dev fork)
# copy the generated json so the app reads it at runtime without a rebuild:
#   cp contracts/deployments/11155111.json apps/web/public/deployment.json
# NEXT_PUBLIC_CHAIN_ID=11155111
# NEXT_PUBLIC_DROP_FACTORY=0x...
# NEXT_PUBLIC_FEE_TOKEN=0x...
# NEXT_PUBLIC_TREASURY=0x...
