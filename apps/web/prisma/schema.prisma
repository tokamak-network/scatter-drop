// Multi-network registry (docs/MULTI-NETWORK-DESIGN.md). SQLite for dev; swap
// DATABASE_URL to Postgres for production.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A supported airdrop network, curated by the platform admin.
model Network {
  chainId          Int      @id
  name             String
  rpcUrl           String   // server-side scan RPC (may hold a key)
  publicRpcUrl     String?  // browser/wagmi RPC (safe to expose)
  explorerUrl      String?
  nativeSymbol     String   @default("ETH")
  dropFactory      String   // required
  feeToken         String?
  treasury         String?
  operatorRegistry String?
  zkFactory        String?
  deployBlock      Int?
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// App-level platform admins allowed to manage the network registry (SIWE).
model PlatformAdmin {
  address   String   @id // lowercased wallet address
  label     String?
  createdAt DateTime @default(now())
}

/// Per-recipient claim proofs for a campaign, keyed by merkleRoot — the
/// off-chain proofs.json seam (DESIGN §8.7/§12), persisted so a dev-server
/// restart no longer wipes eligibility. Stand-in for IPFS pinning; immutable
/// once written (the claims are tied to the root).
model CampaignProofs {
  // Keyed by (chainId, drop) — the vault is the identity, not the merkleRoot.
  // Two vaults can legitimately share a root (same recipient list), so a root
  // PK let the first publisher squat the slot and 409 the others (and let an
  // attacker on any chain block a victim's publish). Scoping to the vault gives
  // each its own row; the on-chain claim is unaffected.
  chainId   Int
  drop      String   // lowercased drop (vault) address
  root      String   // lowercased 0x… merkleRoot (kept for verify + self-describing pin)
  claims    String   // JSON: { [lowercased address]: {index, account, amount, proof[]} }
  count     Int
  cid       String?  // IPFS CID of the pinned proofs.json (when pinning is configured)
  createdAt DateTime @default(now())

  @@id([chainId, drop])
}

/// Operator-entered campaign name/description — collected by the wizard but
/// not part of the on-chain DropCreated event, so persisted here and merged
/// into the campaign list at read time. Create-only (no auth): first write
/// for a drop wins, like CampaignProofs.
model CampaignMeta {
  chainId     Int
  drop        String // lowercased drop (campaign) address
  name        String
  description String?
  createdAt   DateTime @default(now())

  @@id([chainId, drop])
}

/// An operator-posted airdrop pre-announcement (the "Upcoming Drops" board).
/// Lifecycle: UPCOMING → (drop linked) → LIVE → ENDED, plus CANCELED — but
/// LIVE/ENDED are derived at read time from the linked drop's on-chain claim
/// window, so only the copy, the expected window, and the link live here.
/// Writes are SIWE-authenticated; `operator` is the verified poster wallet.
model Announcement {
  id            String    @id @default(cuid())
  chainId       Int
  title         String
  body          String
  tokenSymbol   String?
  tokenAddress  String? // lowercased ERC-20 address of the airdropped token
  expectedStart DateTime
  expectedEnd   DateTime?
  links         String? // JSON: [{label, url}] — external channels (site, X, …)
  drop          String? // lowercased drop address once the campaign is created
  canceled      Boolean   @default(false)
  operator      String // lowercased poster wallet (SIWE-verified)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // The board's hottest read: list by chain ordered by expected start.
  @@index([chainId, expectedStart])
}

// --- Native quests (docs/SOCIAL-TASK-DESIGN.md §5) ---

/// A quest campaign — the container of tasks BEFORE createDrop. On close, the
/// completions aggregate to an (address, amount) list that feeds the existing
/// buildDrop → createDrop(type=SOCIAL) path; `drop` links the result back.
model QuestCampaign {
  id          String            @id @default(cuid())
  chainId     Int
  operator    String // lowercased, SIWE-verified creator
  title       String
  closesAt    DateTime
  amountMode  String // "equal" (v1: equal split only)
  totalAmount String // human-unit amount string, split at aggregation time
  drop        String? // lowercased drop address once createDrop ran
  tasks       QuestTask[]
  completions QuestCompletion[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([operator, chainId])
}

/// One verifiable task inside a campaign. `tier` is derived from `kind`
/// (VERIFIED | METERED | INTENT) and stored for auditability.
model QuestTask {
  id          String            @id @default(cuid())
  campaignId  String
  campaign    QuestCampaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  kind        String // DISCORD_JOIN | DISCORD_ROLE | TELEGRAM_JOIN | GITHUB_STAR | ONCHAIN | LINK_VISIT (X kinds: post-v1)
  config      String // JSON: guildId/roleId, chatId, owner/repo, …
  required    Boolean           @default(true)
  tier        String // VERIFIED | METERED | INTENT
  completions QuestCompletion[]
}

/// A server-verified task completion for a wallet. Composite PK makes the
/// verify endpoint idempotent per (campaign, wallet, task).
model QuestCompletion {
  campaignId String
  campaign   QuestCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  wallet     String // lowercased
  taskId     String
  task       QuestTask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  verifiedAt DateTime      @default(now())
  evidence   String? // JSON: minimal proof (guild member joined_at, …)

  @@id([campaignId, wallet, taskId])
  @@index([campaignId, wallet])
}

/// Sybil axis: 1 social account = 1 wallet. Unbind is SOFT — the row stays
/// (unboundAt set) so cooldowns and history survive; rebinding is allowed only
/// after the cooldown. Verifiers record completions only against an ACTIVE
/// binding (unboundAt = null), and aggregation re-joins against the binding so
/// account-hopping across wallets is excluded (§7).
model WalletSocial {
  provider          String // discord | telegram | github | x
  providerAccountId String
  wallet            String // lowercased — currently (or last) bound wallet
  boundAt           DateTime  @default(now())
  unboundAt         DateTime? // null = active binding
  quality           String? // JSON: account age, joined_at flags, … (scoring signals)
  // Server-only user access token — ONLY GitHub needs it: star-checking is
  // `GET /user/starred/{owner}/{repo}` as the user themselves (design §2.2),
  // so unlike Discord/Telegram (checked via a platform bot token any time),
  // the GITHUB_STAR verifier must re-use this at check time. Never returned
  // by any API response (see questVerifiers/github.ts, /api/quests/*/me).
  accessToken       String?

  @@id([provider, providerAccountId])
  @@index([wallet])
}
