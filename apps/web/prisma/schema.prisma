// Multi-network registry (docs/MULTI-NETWORK-DESIGN.md). SQLite for dev; swap
// DATABASE_URL to Postgres for production.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A supported airdrop network, curated by the platform admin.
model Network {
  chainId          Int      @id
  name             String
  rpcUrl           String   // server-side scan RPC (may hold a key)
  publicRpcUrl     String?  // browser/wagmi RPC (safe to expose)
  explorerUrl      String?
  nativeSymbol     String   @default("ETH")
  dropFactory      String   // required
  feeToken         String?
  treasury         String?
  operatorRegistry String?
  zkFactory        String?
  deployBlock      Int?
  enabled          Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

/// App-level platform admins allowed to manage the network registry (SIWE).
model PlatformAdmin {
  address   String   @id // lowercased wallet address
  label     String?
  createdAt DateTime @default(now())
}

/// Per-recipient claim proofs for a campaign, keyed by merkleRoot — the
/// off-chain proofs.json seam (DESIGN §8.7/§12), persisted so a dev-server
/// restart no longer wipes eligibility. Stand-in for IPFS pinning; immutable
/// once written (the claims are tied to the root).
model CampaignProofs {
  root      String   @id // lowercased 0x… merkleRoot
  claims    String   // JSON: { [lowercased address]: {index, account, amount, proof[]} }
  count     Int
  createdAt DateTime @default(now())
}

/// Operator-entered campaign name/description — collected by the wizard but
/// not part of the on-chain DropCreated event, so persisted here and merged
/// into the campaign list at read time. Create-only (no auth): first write
/// for a drop wins, like CampaignProofs.
model CampaignMeta {
  chainId     Int
  drop        String // lowercased drop (campaign) address
  name        String
  description String?
  createdAt   DateTime @default(now())

  @@id([chainId, drop])
}
